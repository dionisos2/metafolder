{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Metafolder",
  "version": "0.1.0",
  "identifier": "org.metafolder.gui",
  "build": {
    "frontendDist": "frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm --prefix frontend run dev"
  },
  "app": {
    "windows": [
      {
        "title": "Metafolder",
        "width": 1200,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false
  }
}
